{
  "name": "TechNova Dark Analytics",
  "dataColors": [
    "#22D3EE",
    "#8B5CF6",
    "#F59E0B",
    "#EC4899",
    "#10B981",
    "#3B82F6",
    "#F97316",
    "#6366F1",
    "#14B8A6",
    "#EF4444"
  ],
  "background": "#0F172A",
  "foreground": "#E2E8F0",
  "tableAccent": "#22D3EE",
  "maximum": "#10B981",
  "center": "#F59E0B",
  "minimum": "#EF4444",
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI",
      "color": "#F8FAFC"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#E2E8F0"
    },
    "header": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#CBD5E1"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#94A3B8"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 5
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#334155" } },
            "show": true
          }
        ],
        "outlineColor": [
          {
            "solid": { "color": "#334155" }
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#334155" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 10
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#CBD5E1" } },
            "background": { "solid": { "color": "#0F172A" } }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#334155" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#334155" } }
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#CBD5E1" } },
            "backColor": { "solid": { "color": "#1E293B" } }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#F8FAFC" } },
            "backColor": { "solid": { "color": "#0F172A" } }
          }
        ]
      }
    }
  }
}
